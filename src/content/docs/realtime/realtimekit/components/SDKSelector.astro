---
import { z } from "astro:schema";
import SDKSelector from "./SDKSelector/SDKSelector";

const props = z.object({
	showInstallationHelpers: z.boolean().optional(),
});

const { showInstallationHelpers } = props.parse(Astro.props);
---

<SDKSelector client:load showInstallationHelpers={showInstallationHelpers} />
